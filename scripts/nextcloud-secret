#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/nextcloud-secret [mika|bootstrap] [-i /path/to/identity]

Examples:
  scripts/nextcloud-secret mika
  scripts/nextcloud-secret bootstrap
  scripts/nextcloud-secret mika -i ~/.ssh/id_ed25519
EOF
}

identity="${AGE_IDENTITY:-$HOME/.ssh/id_ed25519}"
while getopts ":i:h" opt; do
  case "$opt" in
    i) identity="$OPTARG" ;;
    h)
      usage
      exit 0
      ;;
    \?)
      echo "Invalid option: -$OPTARG" >&2
      usage
      exit 2
      ;;
  esac
done
shift $((OPTIND - 1))

kind="${1:-mika}"

case "$kind" in
  mika)
    secret_file="secrets/nextcloud-mika-pass.age"
    ;;
  bootstrap|admin)
    secret_file="secrets/nextcloud-admin-pass.age"
    ;;
  *)
    echo "Unknown secret type: $kind" >&2
    usage
    exit 2
    ;;
esac

if [[ ! -f "$secret_file" ]]; then
  echo "Secret file not found: $secret_file" >&2
  exit 1
fi

if command -v age >/dev/null 2>&1; then
  age -d -i "$identity" "$secret_file"
else
  nix shell nixpkgs#age -c age -d -i "$identity" "$secret_file"
fi
